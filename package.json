{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development node --env-file=.env ./node_modules/tsx/dist/cli.mjs server/index.ts",
    "dev:test": "NODE_ENV=development node --env-file=.env.test ./node_modules/tsx/dist/cli.mjs server/index.ts",
    "build": "tsx script/build.ts",
    "vercel-build": "npm run build && npm run test:compliance",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "test:compliance": "tsx script/compliance-check.ts",
    "test:guided-summary": "node --env-file=.env script/test-guided-summary.mjs",
    "test:guided-summary:horizon": "TEST_PROJECTION_YEARS=7 node --env-file=.env script/test-guided-summary.mjs --no-save",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push",
    "db:copy:staging": "node --env-file=.env.production --env-file=.env.staging script/copy-production-to-neon.mjs --yes",
    "stripe:setup-test-product": "node --env-file=.env.test script/create-stripe-test-product.mjs",
    "stripe:listen": "stripe listen --forward-to localhost:5000/api/stripe/webhook",
    "stripe:setup-support": "node --env-file=.env.cutover script/create-stripe-support-product.mjs",
    "db:push:cutover": "node --env-file=.env.cutover ./node_modules/drizzle-kit/bin.cjs push --force",
    "vercel:deploy": "bash script/push-vercel-env.sh"
  },
  "dependencies": {

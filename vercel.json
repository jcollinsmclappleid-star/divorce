{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "crons": [
    {
      "path": "/api/cron/nurture-emails",
      "schedule": "*/30 * * * *"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
